{
  "expo": {
    "name": "CSTV",
    "slug": "CSTV",
    "scheme": "cstv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/fuze-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/Splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#161621"
        }
      ]
    ],

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/fuze-icon.png",
        "backgroundColor": "#161621"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jeshuaben.CSTV"
    },

    "ios": {
      "supportsTablet": true
    },

    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}